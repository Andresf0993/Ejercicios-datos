using System;

public class ejercicio_6
{
    public static void Main(String[] Args)
    {
        int tamano = 3;

        for (int i = 0; i < tamano; i++)
        {
            for (int j = 0; j < tamano; j++)
            {
                if (i == j)
                {
                    Console.Write("1 ");
                }
                else
                {
                    Console.Write("0 ");
                }
            }
            Console.WriteLine();
        }
    }
}
